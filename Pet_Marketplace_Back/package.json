{
  "name": "pet-marketplace-back",
  "private": true,
  "version": "0.1.0",
  "description": "Backend NestJS — Pet Marketplace UK (Fase 1, sem pagamento).",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.x",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config jest-e2e.json --runInBand",
    "test:e2e": "jest --config jest-e2e.json",
    "auth:roles:check": "node scripts/auth/check-user-roles.mjs",
    "auth:roles:set": "node scripts/auth/set-user-role.mjs",
    "db:smoke": "node scripts/db/smoke-readonly.mjs",
    "db:smoke:block2b": "node scripts/db/smoke-block2b-readonly.mjs",
    "db:smoke:trust-safety": "node scripts/db/smoke-trust-safety-readonly.mjs",
    "db:smoke:me": "node scripts/db/smoke-me-authenticated.mjs",
    "db:run-sql": "node scripts/db/run-sql-file.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@supabase/supabase-js": "^2.45.0",
    "helmet": "^7.1.0",
    "magic-bytes.js": "^1.13.0",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "ws": "^8.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pg": "^8.21.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "ts-loader": "^9.5.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "license": "UNLICENSED"
}
