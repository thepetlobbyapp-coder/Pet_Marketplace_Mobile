# Backend â€” Fase 1 (SEM pagamento). Copie para .env. NÃ£o commitar segredos.
NODE_ENV=development
API_PORT=3000
API_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=en-GB

# CORS: origens permitidas separadas por virgula. Vazio = somente API_BASE_URL.
# Desenvolvimento Mobile Web: http://localhost:8082,http://localhost:8081
CORS_ALLOWED_ORIGINS=
# Swagger em /api/v1/docs (recomendado false em produÃ§Ã£o).
SWAGGER_ENABLED=true

# Supabase / Postgres / PostGIS (Bloco 1+)
# Sem estas chaves: Auth/DB em modo degradado (503). Health/erros/logs OK.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Block2B smoke fixture (optional, read-only validation)
# Generate locally from the fixture user. Never commit real values.
BLOCK2B_AUTH_ACCESS_TOKEN=
BLOCK2B_TEST_EMAIL=
BLOCK2B_TEST_PASSWORD=

# Geocoding (Bloco 5)
GEOCODING_API_KEY=
