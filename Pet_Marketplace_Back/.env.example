# Backend — Fase 1 (SEM pagamento). Copie para .env. Não commitar segredos.
NODE_ENV=development
API_PORT=3000
API_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=en-GB

# CORS: origens permitidas separadas por vírgula. Vazio = somente API_BASE_URL.
CORS_ALLOWED_ORIGINS=
# Swagger em /api/v1/docs (recomendado false em produção).
SWAGGER_ENABLED=true

# Supabase / Postgres / PostGIS (Bloco 1+)
# Sem estas chaves: Auth/DB em modo degradado (503). Health/erros/logs OK.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Geocoding (Bloco 5)
GEOCODING_API_KEY=
