{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": ".tmp/test-build",
    "rootDir": ".",
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "build", ".next", ".tmp"]
}
