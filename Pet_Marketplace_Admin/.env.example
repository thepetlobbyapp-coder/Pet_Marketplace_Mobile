# Admin — Bloco 9. Copie para .env.local. NUNCA commitar segredos.
APP_DEFAULT_LOCALE=en-GB

# URL absoluta do backend usado por Server Components / route handlers
# (server-only; NÃO prefixar com NEXT_PUBLIC_).
# Local: http://localhost:3000
# Remoto (DigitalOcean): https://stingray-app-vyfrt.ondigitalocean.app
ADMIN_API_BASE_URL=http://localhost:3000

# Supabase Auth no client (anon key apenas). Nunca usar service role aqui.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cookie de sessão admin: nome e idade (segundos). 1h por padrão.
ADMIN_SESSION_COOKIE_NAME=pet-admin-session
ADMIN_SESSION_COOKIE_MAX_AGE=3600
