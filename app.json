{
  "expo": {
    "name": "Pet Marketplace",
    "slug": "pet-marketplace",
    "scheme": "petmarketplace",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "app.thepetlobby.petmarketplace",
      "versionCode": 1,
      "permissions": [],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.VIBRATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "app.thepetlobby.petmarketplace",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "./plugins/with-network-security"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "note": "Fase 1: sem camera/microfone/arquivos/localizacao/push. Ver MOBILE_SECURITY.md",
      "router": {},
      "eas": {
        "projectId": "f28262e9-c276-4bbb-9c07-ebc49fbb900a"
      }
    },
    "owner": "israel_souza"
  }
}
