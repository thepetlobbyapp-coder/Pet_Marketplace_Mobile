# ===== Pet Marketplace UK — template de ambiente (RAIZ) =====
# Copie para .env em cada app conforme necessário. NUNCA commitar .env real.
# Fase 1: SEM chaves de pagamento (Stripe/Wise/Pix proibidos nesta fase).

# --- Comum ---
NODE_ENV=development
APP_DEFAULT_LOCALE=en-GB

# --- Backend (Pet_Marketplace_Back) ---
API_PORT=3000
API_BASE_URL=http://localhost:3000

# --- Supabase (Bloco 1+) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Geocoding (Bloco 5) ---
GEOCODING_API_KEY=

# --- Mobile (Pet_Marketplace_Mobile) ---
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Admin (Pet_Marketplace_Admin) ---
ADMIN_API_BASE_URL=http://localhost:3000
