{
  "name": "pet-marketplace-mobile",
  "private": true,
  "version": "0.1.0",
  "description": "App mobile React Native + Expo - Pet Marketplace UK (en-GB).",
  "main": "expo-router/entry",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.x",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm typecheck && pnpm lint",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.1.1",
    "@supabase/auth-js": "2.106.1",
    "@tanstack/react-query": "^5.100.11",
    "expo": "^56.0.5",
    "expo-constants": "~56.0.16",
    "expo-file-system": "56.0.7",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-image-picker": "56.0.14",
    "expo-linking": "~56.0.12",
    "expo-router": "^56.2.7",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "^56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "license": "UNLICENSED"
}
