# Mobile public runtime config. Copy to .env for local development.
# Only EXPO_PUBLIC_* values are bundled into the app. Never add service-role
# keys, DATABASE_URL, passwords, bearer tokens, or Block2B smoke tokens here.

EXPO_PUBLIC_API_BASE_URL=https://stingray-app-vyfrt.ondigitalocean.app
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ENABLE_DEMO_FIXTURES=false
